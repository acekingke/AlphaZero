digraph tree_vs_dict {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=12, style=filled, fillcolor="white", shape=box, margin="0.15,0.08"];
    edge [fontname="Helvetica", fontsize=10];

    subgraph cluster_tree {
        label=<<B>树实现：同一局面 S 被拆成两个节点</B>>;
        labeljust=c;
        style=rounded;
        color="#999999";
        fontsize=13;
        fontname="Helvetica";

        T0 [label="Root"];
        Ta [label="Node_A"];
        Tb [label="Node_B"];
        Tab [label="S（N=1）", fillcolor="#f4cccc", color="#cc0000", penwidth=2];
        Tba [label="S（N=1）", fillcolor="#f4cccc", color="#cc0000", penwidth=2];

        T0 -> Ta [label=" a "];
        T0 -> Tb [label=" b "];
        Ta -> Tab [label=" b "];
        Tb -> Tba [label=" a "];
    }

    subgraph cluster_dict {
        label=<<B>字典实现：同一局面 S 只有一个条目</B>>;
        labeljust=c;
        style=rounded;
        color="#999999";
        fontsize=13;
        fontname="Helvetica";

        D0 [label="Root"];
        Da [label="Node_A"];
        Db [label="Node_B"];
        DS [label="S（N=2）", fillcolor="#d9ead3", color="#38761d", penwidth=2];

        D0 -> Da [label=" a "];
        D0 -> Db [label=" b "];
        Da -> DS [label=" b "];
        Db -> DS [label=" a "];
    }

    // invisible edge to align clusters left-right
    T0 -> D0 [style=invis, minlen=3];
}
